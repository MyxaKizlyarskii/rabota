        private void AddToCart(string emoji, string name, decimal price)
        {
            foreach (var item in cartItems)
            {
                if (item.Name == name)
                {
                    item.Quantity++;
                    UpdateCartDisplay();
                    ShowNotification("Добавлено в корзину", $"{name}\n\nКоличество: {item.Quantity}\nСумма: {price * item.Quantity} ₽", "➕", Color.FromArgb(76, 175, 80));
                    return;
                }
            }

            cartItems.Add(new CartItem { Emoji = emoji, Name = name, Price = price, Quantity = 1 });
            UpdateCartDisplay();
            ShowNotification("Добавлено в корзину", $"{name}\n\nЦена: {price} ₽\nКоличество: 1", "✅", Color.FromArgb(76, 175, 80));
        }

