        private void UpdateCartDisplay()
        {
            if (cartFlowPanel == null) return;
            cartFlowPanel.Controls.Clear();

            if (cartItems.Count == 0)
            {
                Label emptyLabel = new Label();
                emptyLabel.Text = "🛒 КОРЗИНА ПУСТА\n\nДобавьте блюда из раздела МЕНЮ";
                emptyLabel.Font = new Font("Segoe UI", 16, FontStyle.Bold);
                emptyLabel.ForeColor = Color.Gray;
                emptyLabel.Size = new Size(500, 100);
                emptyLabel.TextAlign = ContentAlignment.MiddleCenter;
                cartFlowPanel.Controls.Add(emptyLabel);
                return;
            }

            foreach (var item in cartItems)
            {
                Panel cartCard = CreateCartCard(item);
                cartFlowPanel.Controls.Add(cartCard);
            }
        }

